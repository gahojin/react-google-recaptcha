{
  "name": "root",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/react-google-recaptcha.git"
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "build": "turbo run build --filter=!./examples/* --filter=!*props-docs",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "check": "turbo run check",
    "test": "turbo run test:unit --filter=!./examples/* --filter=!*props-docs",
    "clean": "turbo run clean --filter=!./examples/* --filter=!*props-docs",
    "ncu": "mise run ncu"
  },
  "dependencies": {
    "@biomejs/biome": "catalog:",
    "@fast-check/vitest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.5.1"
}
