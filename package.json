{
  "name": "root",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/react-google-recaptcha.git"
  },
  "scripts": {
    "postinstall": "biome migrate --write",
    "build": "turbo run build --filter=!./examples/* --filter=!*props-docs",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "check": "turbo run check",
    "check:packagejson": "turbo run check:packagejson",
    "test": "turbo run test:unit --filter=!./examples/* --filter=!*props-docs",
    "clean": "turbo run clean --filter=!./examples/* --filter=!*props-docs",
    "ncu": "mise run ncu"
  },
  "dependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.12",
    "@fast-check/vitest": "0.4.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "jest-extended": "7.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rolldown": "1.0.0-rc.16",
    "rolldown-plugin-dts": "0.23.2",
    "terser": "5.46.1",
    "turbo": "2.9.6",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  },
  "packageManager": "pnpm@10.33.0"
}
