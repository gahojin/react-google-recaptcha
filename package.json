{
  "name": "root",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/react-google-recaptcha.git"
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "build": "turbo run build --filter=!./examples/* --filter=!*props-docs",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "check": "turbo run check",
    "test": "turbo run test:unit --filter=!./examples/* --filter=!*props-docs",
    "clean": "turbo run clean --filter=!./examples/* --filter=!*props-docs",
    "ncu": "mise run ncu"
  },
  "dependencies": {
    "@biomejs/biome": "2.4.16",
    "@fast-check/vitest": "0.4.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "turbo": "2.9.18",
    "typescript": "6.0.3",
    "unplugin-dts": "1.0.2",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.5.1"
}
